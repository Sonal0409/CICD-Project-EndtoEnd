pipeline{
    agent any
    tools{
        maven 'mymaven'
    }
    stages{
        stage('Checkout the Code')
        {
            steps{
                git 'https://github.com/Sonal0409/DevOpsCodeDemo.git'
            }
        }
        stage('Test Code')
        {
            steps{
                sh 'mvn test'
            }
        }

        stage('Build Code')
        {
            steps{
                sh 'mvn package'
            }
        }
    }
}